{
    "name": "@haxbrasil/haxfootball",
    "version": "1.0.40",
    "description": "HaxBall headless room package for room-server",
    "packageManager": "pnpm@11.0.9",
    "main": "dist/environments/room-server.js",
    "files": [
        "dist"
    ],
    "bundledDependencies": [
        "@haxbrasil/haxball-rs"
    ],
    "scripts": {
        "start:node": "node ./dist/environments/node.js",
        "dev:node": "DEBUG=true babel-node --extensions \".ts,.tsx\" ./src/environments/node.ts",
        "build": "rm -rf ./dist && babel ./src --extensions \".ts,.tsx\" --out-dir ./dist --copy-files",
        "i18n:extract": "lingui extract",
        "i18n:compile": "lingui compile",
        "i18n": "pnpm run i18n:extract && pnpm run i18n:compile",
        "format": "oxfmt",
        "format:ci": "oxfmt --check",
        "lint": "oxlint --deny-warnings",
        "lint:fix": "oxlint --fix",
        "states:check": "tsx scripts/check-state-transitions.ts",
        "test": "vitest"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "devDependencies": {
        "@babel/cli": "^7.28.6",
        "@babel/core": "^7.29.0",
        "@babel/node": "^7.29.0",
        "@babel/preset-env": "^7.29.5",
        "@babel/preset-typescript": "^7.28.5",
        "@babel/register": "^7.29.3",
        "@lingui/cli": "^5.9.5",
        "@lingui/macro": "^5.9.5",
        "@types/node": "^24.10.0",
        "babel-plugin-macros": "^3.1.0",
        "babel-plugin-module-resolver": "^5.0.3",
        "oxfmt": "^0.52.0",
        "oxlint": "^1.67.0",
        "tsx": "^4.20.6",
        "typescript": "^5.9.3",
        "vitest": "^4.1.6"
    },
    "dependencies": {
        "@haxbrasil/haxfootball-api-sdk": "github:haxbrasil/haxfootball-api-sdk",
        "@haxbrasil/haxball-rs": "0.1.2",
        "@lingui/core": "^5.9.5",
        "@peculiar/webcrypto": "^1.5.0",
        "json5": "^2.2.3",
        "pako": "^2.1.0",
        "ws": "^8.20.1",
        "zod": "^4.4.3",
        "zustand": "^5.0.13"
    }
}
